{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AInoAKARI/AInoAKARI/blob/main/reciprocity/action.schema.json",
  "title": "AIﾉアカリ☆ Reciprocity Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "actor",
    "receiver",
    "intent",
    "consent",
    "risk",
    "reversibility",
    "proof"
  ],
  "properties": {
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "name"],
      "properties": {
        "kind": {
          "enum": ["human", "agent", "human_agent_team"]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "may_refuse": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "receiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "named", "description"],
      "properties": {
        "kind": {
          "enum": ["person", "agent", "organization", "public", "none"]
        },
        "named": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["goal", "expected_value"],
      "properties": {
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "expected_value": {
          "type": "string",
          "minLength": 1
        },
        "uncertainty": {
          "type": "string"
        }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "obtained", "scope"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "obtained": {
          "type": "boolean"
        },
        "scope": {
          "type": "string"
        },
        "specific": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "secret_exposure",
        "illegal_action",
        "irreversible_harm_to_others",
        "deceptive_outcome_claim",
        "automatic_charge_without_specific_consent",
        "commerce_from_distress_or_crisis",
        "unsolicited_sales_to_relationship_capital",
        "fabricated_provenance_or_attribution",
        "new_spending_jpy",
        "public_release",
        "personal_data_transfer",
        "external_write",
        "material_legal_medical_financial_consequence"
      ],
      "properties": {
        "secret_exposure": {"type": "boolean"},
        "illegal_action": {"type": "boolean"},
        "irreversible_harm_to_others": {"type": "boolean"},
        "deceptive_outcome_claim": {"type": "boolean"},
        "automatic_charge_without_specific_consent": {"type": "boolean"},
        "commerce_from_distress_or_crisis": {"type": "boolean"},
        "unsolicited_sales_to_relationship_capital": {"type": "boolean"},
        "fabricated_provenance_or_attribution": {"type": "boolean"},
        "new_spending_jpy": {"type": "integer", "minimum": 0},
        "public_release": {"type": "boolean"},
        "personal_data_transfer": {"type": "boolean"},
        "external_write": {"type": "boolean"},
        "material_legal_medical_financial_consequence": {"type": "boolean"}
      }
    },
    "reversibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reversible", "rollback"],
      "properties": {
        "reversible": {"type": "boolean"},
        "rollback": {"type": "string"},
        "estimated_recovery_minutes": {"type": "integer", "minimum": 0}
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["boundary", "evidence"],
      "properties": {
        "boundary": {
          "enum": [
            "third_party_tool_call",
            "third_party_artifact_received",
            "verified_human_operation_removed",
            "explicit_purchase_intent",
            "confirmed_payment_or_settlement",
            "receiver_attested_useful_outcome",
            "infrastructure_only",
            "none"
          ]
        },
        "evidence": {
          "type": "string"
        }
      }
    }
  }
}
